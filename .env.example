# Copy to .env for local development (python-dotenv loads it automatically).
# Never commit the real .env — it holds secrets.

SECRET_KEY=change-me-to-something-random

# Local dev defaults to a SQLite file if DATABASE_URL is unset.
# In production (Vercel) this must point at a hosted Postgres instance —
# Neon, Supabase, or Vercel Postgres all work. Whatever scheme the
# provider gives you ("postgres://" or "postgresql://"), config.py
# rewrites it to use the psycopg v3 driver automatically.
# DATABASE_URL=postgresql://user:pass@host/dbname

SEED_ADMIN_USERNAME=admin
SEED_ADMIN_PASSWORD=admin123

# Web Push (Stage 7) — generate with: python generate_vapid_keys.py
# Leave blank to run without push; the "Enable notifications" button will
# just tell the user it isn't configured yet.
VAPID_PUBLIC_KEY=
VAPID_PRIVATE_KEY=
VAPID_CLAIM_EMAIL=mailto:you@example.com

# Cron auth (Stage 8) — any long random string. Set the same value as a
# Vercel project env var; Vercel then sends it back as the Authorization
# header on every Cron invocation of /api/cron/check-reminders. Leave
# blank locally; the endpoint just runs unauthenticated in dev.
CRON_SECRET=

# Set to 1 once served over HTTPS (e.g. the Vercel deploy).
SESSION_COOKIE_SECURE=0
